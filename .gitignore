Build/
.DS_Store
*_extdep/
*.pyc
__pycache__/
tags/
.vscode/
.venv/
PROJECT.txt
AUTOMATION.txt

# Production-first hygiene additions
# Build artifacts and outputs
out/

# Object/library artifacts
utils/*.o
utils/*.a
utils/*.so
utils/*.so.*
utils/pgmodverify_test

# Virtual environments anywhere in the tree
**/.venv/
**/venv/

# Large vendor/artifact directories
isos/
nuclear-cd-build/iso/
nuclear-cd-build/iso/recovery/drivers/
BIOS_Samples/

# Safety net: ignore ISO files anywhere
*.iso

# Build dir (generated artifacts)
build/
!components/*/build/
!components/*/build/.gitkeep

# Large demo archives
examples_and_samples/demo/**/*.tar.gz

# Session/process leftovers
# Prevent accidental inclusion of nohup outputs anywhere in the tree
nohup.out
nohup.out*
nohup*.out

# Editor backup files
*~
*.bak
*.swp
*.swo
.pf_archive/

# Hex dump artifacts
*.xxd
*.xxd.xxd
*.xxd.xxd.xxd

# Local indexer / bish caches (never tracked, anywhere in the tree)
.bish-index
.bish.sqlite
**/.bish-index
**/.bish.sqlite

# Podman / Buildah rootless storage leftovers
# (these accidentally land in the repo if podman is run from cwd)
/overlay/
/overlay-containers/
/overlay-images/
/overlay-layers/
**/overlay/.has-mount-program
**/*.lock

# Kernel modules are user-specific artifacts, never tracked
*.ko
*.ko.unsigned
*.ko.zst

# Pre-built native libraries should be produced by the build, not tracked
*.o
*.a
*.so
*.so.*

# Stray podman/sqlite dumps at the repo root
/db.sql

# Demo / vendor sample tree (license + size); fetched out-of-band for alpha
examples_and_samples/

# Generated documentation files
copilot-instructions.md
WARP.md

# Environment and secrets - NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/

# Local development databases
*.db
*.sqlite
*.sqlite3
hardware_profiles.db
hardware_uploads/

# Temporary test files
test_output/
tmp/
.tmp/
