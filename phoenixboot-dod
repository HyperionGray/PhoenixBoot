#!/usr/bin/env bash
# phoenixboot-dod - PhoenixBoot CLI for Department of Defense (DoD) Compliance
#
# This CLI is verified against DISA Security Technical Implementation Guides (STIGs)
# and performs only DoD-compliant operations.  All cryptographic operations use
# NIST-approved algorithms (FIPS 140-2/140-3).
#
# Applicable standards:
#   - DISA STIG for Red Hat Enterprise Linux 8/9
#   - NIST SP 800-147  (BIOS Protection Guidelines)
#   - NIST SP 800-147B (BIOS Protection Guidelines for Servers)
#   - NIST SP 800-155  (BIOS Integrity Measurement)
#   - NIST SP 800-131A (Transitioning Use of Cryptographic Algorithms)
#   - FIPS 140-2 / 140-3 (Cryptographic Module Validation)
#
# Usage: ./phoenixboot-dod <command> [options]

set -euo pipefail

# ---------------------------------------------------------------------------
# DoD mode flag – exported so that pf.py and sub-scripts can detect DoD mode
# ---------------------------------------------------------------------------
export DOD_MODE=1
export DOD_FIPS_REQUIRED="${DOD_FIPS_REQUIRED:-0}"

# ---------------------------------------------------------------------------
# Audit logging
# ---------------------------------------------------------------------------
DOD_AUDIT_LOG=""   # set after PHOENIX_ROOT is resolved

dod_audit_log() {
  local msg="$1"
  local ts
  ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  local user="${USER:-$(id -un 2>/dev/null || echo unknown)}"
  local entry="[$ts] [DOD-AUDIT] user=$user cmd=${DOD_AUDIT_CMD:-unknown} -- $msg"

  # Always echo to stderr so it appears in terminal without polluting stdout
  echo "$entry" >&2

  # Write to log file if available
  if [ -n "$DOD_AUDIT_LOG" ]; then
    mkdir -p "$(dirname "$DOD_AUDIT_LOG")"
    echo "$entry" >> "$DOD_AUDIT_LOG"
  fi
}

# ---------------------------------------------------------------------------
# Root discovery (shared with phoenixboot)
# ---------------------------------------------------------------------------
find_phoenix_root() {
  local dir="$1"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/pf.py" ] && [ -f "$dir/Pfyfile.pf" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

# ---------------------------------------------------------------------------
# Usage / help
# ---------------------------------------------------------------------------
usage() {
  cat <<'EOF'
Usage: ./phoenixboot-dod <command> [options]

PhoenixBoot - Department of Defense (DoD) Compliance CLI
Verified against DISA STIGs and NIST SP 800-147/155 guidelines.

Common commands:
  setup
  build
  verify
  status
  list
  test
  test-all
  usb --device /dev/sdX

Secure Boot commands (DISA STIG RHEL-08-010370 / RHEL-08-010372):
  secure keygen
  secure auth
  secure enroll
  secure check
  secure media --iso <path> [--usb-device /dev/sdX]
  secure mok-new [--name NAME] [--cn COMMON_NAME]
  secure mok-enroll [--cert-pem <path>] [--cert-der <path>] [--dry-run]
  secure mok-list
  secure kmod-sign --module <file|dir> [--force]

DoD-specific commands:
  dod-check          Run full DISA STIG compliance pre-flight check
  dod-audit-log      Display the DoD audit log for this session
  dod-status         Show DoD/FIPS compliance status of the current system

Advanced:
  Any unknown command is passed directly to ./pf.py.

Environment:
  DOD_FIPS_REQUIRED=1   Abort if FIPS mode is not active on the host kernel
  DOD_AUDIT_LOG=<path>  Override default audit log path
                        (default: <PHOENIX_ROOT>/logs/dod-audit.log)
EOF
}

# ---------------------------------------------------------------------------
# DoD pre-flight: check FIPS mode, Secure Boot, and audit capability
# ---------------------------------------------------------------------------
dod_preflight() {
  local cmd="$1"
  shift || true
  DOD_AUDIT_CMD="$cmd"

  # ---- FIPS check --------------------------------------------------------
  local fips_enabled=0
  if [ -r /proc/sys/crypto/fips_enabled ]; then
    fips_enabled=$(cat /proc/sys/crypto/fips_enabled)
  fi

  if [ "$fips_enabled" = "1" ]; then
    dod_audit_log "FIPS 140-2/140-3 mode: ACTIVE"
  else
    if [ "${DOD_FIPS_REQUIRED:-0}" = "1" ]; then
      echo "ERROR [DOD]: FIPS mode is required (DOD_FIPS_REQUIRED=1) but kernel" >&2
      echo "             reports FIPS mode is NOT active (/proc/sys/crypto/fips_enabled=0)." >&2
      echo "             Boot with fips=1 kernel parameter or configure FIPS on this system." >&2
      dod_audit_log "ABORT: FIPS mode not active; DOD_FIPS_REQUIRED=1"
      exit 1
    else
      dod_audit_log "FIPS 140-2/140-3 mode: NOT ACTIVE (set DOD_FIPS_REQUIRED=1 to enforce)"
    fi
  fi

  # ---- Secure Boot check (informational) --------------------------------
  local sb_status="unknown"
  if command -v mokutil &>/dev/null; then
    sb_status=$(mokutil --sb-state 2>/dev/null | grep -i 'SecureBoot' | head -1 || echo "unknown")
  elif [ -d /sys/firmware/efi ]; then
    local sb_file
    sb_file=$(ls /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | head -1 || true)
    if [ -n "$sb_file" ]; then
      local sb_byte
      sb_byte=$(od -An -t u1 -j 4 -N 1 "$sb_file" 2>/dev/null | tr -d ' ' || echo "0")
      [ "$sb_byte" = "1" ] && sb_status="SecureBoot enabled" || sb_status="SecureBoot disabled"
    fi
  fi
  dod_audit_log "Secure Boot status: $sb_status"

  # ---- Audit log setup ---------------------------------------------------
  dod_audit_log "DoD CLI invoked: phoenixboot-dod $cmd ${*:-}"
}

# ---------------------------------------------------------------------------
# run_pf: wrapper that always passes DOD_MODE to pf.py
# ---------------------------------------------------------------------------
run_pf() {
  DOD_MODE=1 ./pf.py "$@"
}

# ---------------------------------------------------------------------------
# DoD-specific commands
# ---------------------------------------------------------------------------

cmd_dod_check() {
  dod_audit_log "Running DoD/DISA STIG compliance check"

  echo ""
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║        PhoenixBoot DoD Compliance Check                         ║"
  echo "║        DISA STIG / NIST SP 800-147 / FIPS 140-2                ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""

  local pass=0
  local warn=0
  local fail=0

  _check() {
    local id="$1"
    local desc="$2"
    local result="$3"  # PASS | WARN | FAIL
    local detail="${4:-}"
    local color_pass='\033[0;32m'
    local color_warn='\033[1;33m'
    local color_fail='\033[0;31m'
    local nc='\033[0m'
    case "$result" in
      PASS) echo -e "  [${color_pass}PASS${nc}] $id  $desc"; pass=$((pass+1)) ;;
      WARN) echo -e "  [${color_warn}WARN${nc}] $id  $desc"; [ -n "$detail" ] && echo "           $detail"; warn=$((warn+1)) ;;
      FAIL) echo -e "  [${color_fail}FAIL${nc}] $id  $desc"; [ -n "$detail" ] && echo "           $detail"; fail=$((fail+1)) ;;
    esac
    dod_audit_log "CHECK $result [$id] $desc ${detail:+-- $detail}"
  }

  # --- FIPS Mode -----------------------------------------------------------
  echo "  [ Cryptographic Compliance - FIPS 140-2/140-3 ]"
  local fips_enabled=0
  [ -r /proc/sys/crypto/fips_enabled ] && fips_enabled=$(cat /proc/sys/crypto/fips_enabled)
  if [ "$fips_enabled" = "1" ]; then
    _check "FIPS-001" "Kernel FIPS mode active" PASS
  else
    _check "FIPS-001" "Kernel FIPS mode active" WARN \
      "FIPS mode not detected; boot with fips=1 for full FIPS 140-2/140-3 compliance"
  fi

  # Check OpenSSL FIPS provider
  if openssl list -providers 2>/dev/null | grep -q 'fips'; then
    _check "FIPS-002" "OpenSSL FIPS provider available" PASS
  else
    _check "FIPS-002" "OpenSSL FIPS provider available" WARN \
      "OpenSSL FIPS provider not found; non-FIPS algorithms may be used"
  fi

  # --- Secure Boot (DISA STIG RHEL-08-010370) ------------------------------
  echo ""
  echo "  [ Secure Boot - DISA STIG RHEL-08-010370 ]"
  if [ -d /sys/firmware/efi ]; then
    _check "STIG-SB-001" "UEFI system (Secure Boot capable)" PASS
  else
    _check "STIG-SB-001" "UEFI system (Secure Boot capable)" WARN \
      "Legacy BIOS detected; UEFI required for Secure Boot"
  fi

  local sb_file
  sb_file=$(ls /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | head -1 || true)
  if [ -n "$sb_file" ]; then
    local sb_byte
    sb_byte=$(od -An -t u1 -j 4 -N 1 "$sb_file" 2>/dev/null | tr -d ' ' || echo "0")
    if [ "$sb_byte" = "1" ]; then
      _check "STIG-SB-002" "Secure Boot enabled" PASS
    else
      _check "STIG-SB-002" "Secure Boot enabled" FAIL \
        "Secure Boot is disabled; required by DISA STIG RHEL-08-010370"
    fi
  elif command -v mokutil &>/dev/null && mokutil --sb-state 2>/dev/null | grep -q "SecureBoot enabled"; then
    _check "STIG-SB-002" "Secure Boot enabled" PASS
  else
    _check "STIG-SB-002" "Secure Boot enabled" WARN \
      "Unable to determine Secure Boot status; verify via BIOS/UEFI firmware settings"
  fi

  # --- Kernel Module Signing (DISA STIG RHEL-08-010370) --------------------
  echo ""
  echo "  [ Kernel Module Signing - DISA STIG RHEL-08-010370 ]"
  local kconfig=""
  if [ -r /proc/config.gz ]; then
    kconfig="/proc/config.gz"
  elif [ -r "/boot/config-$(uname -r 2>/dev/null)" ]; then
    kconfig="/boot/config-$(uname -r)"
  fi

  if [ -n "$kconfig" ]; then
    local _grep_cfg
    if [ "${kconfig%.gz}" != "$kconfig" ]; then
      _grep_cfg="zgrep -q"
    else
      _grep_cfg="grep -q"
    fi

    $(_grep_cfg "CONFIG_MODULE_SIG_FORCE=y" "$kconfig" 2>/dev/null) && \
      _check "STIG-KMS-001" "CONFIG_MODULE_SIG_FORCE=y (require signed modules)" PASS || \
      _check "STIG-KMS-001" "CONFIG_MODULE_SIG_FORCE=y (require signed modules)" WARN \
        "Unsigned kernel modules may be loaded; see DISA STIG RHEL-08-010370"

    $(_grep_cfg "CONFIG_MODULE_SIG=y" "$kconfig" 2>/dev/null) && \
      _check "STIG-KMS-002" "CONFIG_MODULE_SIG=y (module signature verification)" PASS || \
      _check "STIG-KMS-002" "CONFIG_MODULE_SIG=y (module signature verification)" WARN \
        "Enable CONFIG_MODULE_SIG=y for module signature support"
  else
    _check "STIG-KMS-001" "Kernel config accessible for module-sig checks" WARN \
      "Cannot find kernel config; install kernel-devel or enable CONFIG_IKCONFIG_PROC"
  fi

  # --- kexec disabled (DISA STIG RHEL-08-010372) ---------------------------
  echo ""
  echo "  [ kexec Control - DISA STIG RHEL-08-010372 ]"
  if [ -n "$kconfig" ]; then
    local _kexec_grep
    if [ "${kconfig%.gz}" != "$kconfig" ]; then
      _kexec_grep() { zgrep -q "$@"; }
    else
      _kexec_grep() { grep -q "$@"; }
    fi

    if _kexec_grep "CONFIG_KEXEC=n" "$kconfig" 2>/dev/null || \
       ! _kexec_grep "CONFIG_KEXEC=y" "$kconfig" 2>/dev/null; then
      _check "STIG-KX-001" "CONFIG_KEXEC disabled (prevents Secure Boot bypass)" PASS
    else
      _check "STIG-KX-001" "CONFIG_KEXEC disabled (prevents Secure Boot bypass)" WARN \
        "kexec can bypass Secure Boot; disable unless required (DISA STIG RHEL-08-010372)"
    fi
  else
    _check "STIG-KX-001" "kexec status (kernel config not accessible)" WARN \
      "Cannot verify kexec status without kernel config"
  fi

  # --- SELinux (DISA STIG RHEL-08-010170) ----------------------------------
  echo ""
  echo "  [ Mandatory Access Control - DISA STIG RHEL-08-010170 ]"
  if command -v getenforce &>/dev/null; then
    local se_status
    se_status=$(getenforce 2>/dev/null || echo "Unknown")
    if [ "$se_status" = "Enforcing" ]; then
      _check "STIG-MAC-001" "SELinux in Enforcing mode" PASS
    elif [ "$se_status" = "Permissive" ]; then
      _check "STIG-MAC-001" "SELinux in Enforcing mode" WARN \
        "SELinux is Permissive; set to Enforcing per DISA STIG RHEL-08-010170"
    else
      _check "STIG-MAC-001" "SELinux in Enforcing mode" FAIL \
        "SELinux is disabled; required by DISA STIG RHEL-08-010170"
    fi
  else
    # Check for AppArmor as an alternative MAC
    if command -v aa-status &>/dev/null && aa-status 2>/dev/null | grep -q "profiles are in enforce mode"; then
      _check "STIG-MAC-001" "AppArmor enforce mode (MAC alternative to SELinux)" PASS
    else
      _check "STIG-MAC-001" "Mandatory Access Control (SELinux/AppArmor)" WARN \
        "Cannot determine MAC status; install selinux-utils or apparmor-utils"
    fi
  fi

  # --- KASLR (DISA STIG RHEL-08-010430) ------------------------------------
  echo ""
  echo "  [ KASLR / Memory Protection - DISA STIG RHEL-08-010430 ]"
  if [ -n "$kconfig" ]; then
    if [ "${kconfig%.gz}" != "$kconfig" ]; then
      zgrep -q "CONFIG_RANDOMIZE_BASE=y" "$kconfig" 2>/dev/null && \
        _check "STIG-KASLR-001" "CONFIG_RANDOMIZE_BASE=y (KASLR)" PASS || \
        _check "STIG-KASLR-001" "CONFIG_RANDOMIZE_BASE=y (KASLR)" FAIL \
          "KASLR disabled; required by DISA STIG RHEL-08-010430"
    else
      grep -q "CONFIG_RANDOMIZE_BASE=y" "$kconfig" 2>/dev/null && \
        _check "STIG-KASLR-001" "CONFIG_RANDOMIZE_BASE=y (KASLR)" PASS || \
        _check "STIG-KASLR-001" "CONFIG_RANDOMIZE_BASE=y (KASLR)" FAIL \
          "KASLR disabled; required by DISA STIG RHEL-08-010430"
    fi
  else
    _check "STIG-KASLR-001" "KASLR status (kernel config not accessible)" WARN \
      "Cannot verify KASLR without kernel config"
  fi

  # --- Key file permissions ------------------------------------------------
  echo ""
  echo "  [ SecureBoot Key File Security ]"
  if [ -d "$PHOENIX_ROOT/keys" ]; then
    local bad_perms=0
    while IFS= read -r -d '' keyfile; do
      local perms
      perms=$(stat -c '%a' "$keyfile" 2>/dev/null || echo "000")
      # Private key files (.key) must be owner-only (600 or stricter)
      if [[ "$keyfile" == *.key ]] && [ "$perms" != "600" ] && [ "$perms" != "400" ]; then
        _check "DOD-KEY-001" "Private key permissions: $keyfile ($perms)" FAIL \
          "Private keys must be chmod 600 or 400 (owner read-only)"
        bad_perms=$((bad_perms+1))
      fi
    done < <(find "$PHOENIX_ROOT/keys" -name "*.key" -print0 2>/dev/null)
    if [ "$bad_perms" -eq 0 ]; then
      _check "DOD-KEY-001" "Private key file permissions (mode 600/400)" PASS
    fi
  else
    _check "DOD-KEY-001" "SecureBoot keys directory present" WARN \
      "keys/ directory not found; run 'phoenixboot-dod secure keygen' first"
  fi

  # --- Summary -------------------------------------------------------------
  echo ""
  echo "══════════════════════════════════════════════════════════════════"
  printf "  DoD Compliance Results:  "
  printf '\033[0;32mPASS: %d\033[0m  ' "$pass"
  printf '\033[1;33mWARN: %d\033[0m  ' "$warn"
  printf '\033[0;31mFAIL: %d\033[0m\n' "$fail"
  echo "══════════════════════════════════════════════════════════════════"
  echo ""
  echo "  References:"
  echo "    DISA STIG RHEL-08-010170  https://www.stigviewer.com/stig/red_hat_enterprise_linux_8/"
  echo "    DISA STIG RHEL-08-010370  https://www.stigviewer.com/stig/red_hat_enterprise_linux_8/"
  echo "    DISA STIG RHEL-08-010372  https://www.stigviewer.com/stig/red_hat_enterprise_linux_8/"
  echo "    DISA STIG RHEL-08-010430  https://www.stigviewer.com/stig/red_hat_enterprise_linux_8/"
  echo "    NIST SP 800-147           https://doi.org/10.6028/NIST.SP.800-147"
  echo "    NIST SP 800-155           https://csrc.nist.gov/publications/detail/sp/800-155/draft"
  echo "    FIPS 140-2/140-3          https://csrc.nist.gov/publications/fips"
  echo ""

  dod_audit_log "dod-check complete: PASS=$pass WARN=$warn FAIL=$fail"

  if [ "$fail" -gt 0 ]; then
    return 1
  fi
  return 0
}

cmd_dod_audit_log() {
  if [ -n "$DOD_AUDIT_LOG" ] && [ -f "$DOD_AUDIT_LOG" ]; then
    echo "=== DoD Audit Log: $DOD_AUDIT_LOG ==="
    cat "$DOD_AUDIT_LOG"
  else
    echo "No DoD audit log found (expected: ${DOD_AUDIT_LOG:-<not set>})" >&2
  fi
}

cmd_dod_status() {
  dod_audit_log "Checking DoD/FIPS system status"
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════╗"
  echo "║        PhoenixBoot DoD / FIPS Status                           ║"
  echo "╚══════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "  PHOENIX_ROOT  : $PHOENIX_ROOT"
  echo "  DOD_MODE      : ${DOD_MODE:-unset} (always 1 for this CLI)"
  echo ""

  # FIPS
  local fips_enabled=0
  [ -r /proc/sys/crypto/fips_enabled ] && fips_enabled=$(cat /proc/sys/crypto/fips_enabled)
  echo -n "  FIPS mode     : "
  [ "$fips_enabled" = "1" ] && echo "ACTIVE (kernel reports FIPS enabled)" || \
    echo "NOT ACTIVE (/proc/sys/crypto/fips_enabled=${fips_enabled:-n/a})"

  # OpenSSL version
  echo -n "  OpenSSL       : "
  openssl version 2>/dev/null | head -1 || echo "not installed"

  # Secure Boot
  echo -n "  Secure Boot   : "
  if command -v mokutil &>/dev/null; then
    mokutil --sb-state 2>/dev/null | head -1 || echo "unknown"
  else
    echo "unknown (mokutil not installed)"
  fi

  # SELinux
  echo -n "  SELinux       : "
  if command -v getenforce &>/dev/null; then
    getenforce 2>/dev/null || echo "unknown"
  else
    echo "not installed"
  fi

  echo ""
  echo "  To run full DISA STIG compliance check:"
  echo "    ./phoenixboot-dod dod-check"
  echo ""
  echo "  Audit log: ${DOD_AUDIT_LOG:-<not set>}"
  echo ""
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

if [ -n "${PHOENIX_ROOT:-}" ] && [ -f "${PHOENIX_ROOT}/pf.py" ] && [ -f "${PHOENIX_ROOT}/Pfyfile.pf" ]; then
  :
elif PHOENIX_ROOT="$(find_phoenix_root "$SCRIPT_DIR")"; then
  :
elif PHOENIX_ROOT="$(find_phoenix_root "$(pwd)")"; then
  :
else
  echo "Error: unable to locate PhoenixBoot root (pf.py + Pfyfile.pf)." >&2
  exit 1
fi

cd "$PHOENIX_ROOT"

# Set up audit log path (allow override via env var)
DOD_AUDIT_LOG="${DOD_AUDIT_LOG:-$PHOENIX_ROOT/logs/dod-audit.log}"

cmd="${1:-help}"
shift || true

# Run DoD pre-flight for all commands except help/status display
case "$cmd" in
  help|-h|--help|dod-audit-log)
    : # skip preflight for pure display commands
    ;;
  *)
    dod_preflight "$cmd" "$@"
    ;;
esac

case "$cmd" in
  help|-h|--help)
    usage
    ;;

  setup)
    run_pf setup
    ;;

  build)
    run_pf build-build build-package-esp
    ;;

  verify)
    run_pf verify
    ;;

  status)
    echo "Working from: $PHOENIX_ROOT"
    echo -n "ESP image: "
    [ -f out/esp/esp.img ] && du -h out/esp/esp.img | awk '{print $1}' || echo "missing"
    echo -n "BootX64.efi: "
    [ -f out/staging/BootX64.efi ] && echo "ready" || echo "missing"
    echo -n "UUEFI.efi: "
    [ -f staging/boot/UUEFI.efi ] && echo "ready" || echo "missing"
    echo -n "Keys: "
    [ -f keys/PK.crt ] && echo "present" || echo "missing"
    ;;

  list)
    run_pf list
    ;;

  test)
    run_pf test-qemu
    ;;

  test-all)
    run_pf test-qemu test-qemu-secure-positive test-qemu-uuefi
    ;;

  usb)
    usb_device=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --device)
          usb_device="${2:-}"
          shift 2
          ;;
        *)
          if [ -z "$usb_device" ]; then
            usb_device="$1"
            shift
          else
            echo "Unknown usb option: $1" >&2
            exit 2
          fi
          ;;
      esac
    done
    [ -n "$usb_device" ] || { echo "Usage: ./phoenixboot-dod usb --device /dev/sdX" >&2; exit 2; }
    USB_DEVICE="$usb_device" USB_DEVICE_CONFIRM=I_UNDERSTAND run_pf workflow-usb-write-dd
    ;;

  secure)
    sub="${1:-}"
    shift || true
    case "$sub" in
      keygen)
        run_pf secure-keygen
        ;;
      auth)
        run_pf secure-make-auth
        ;;
      enroll)
        run_pf secure-enroll-secureboot
        ;;
      check)
        run_pf secureboot-check
        ;;
      media)
        iso_path=""
        usb_device=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --iso) iso_path="${2:-}"; shift 2 ;;
            --usb-device) usb_device="${2:-}"; shift 2 ;;
            *)
              echo "Unknown secure media option: $1" >&2
              exit 2
              ;;
          esac
        done
        [ -n "$iso_path" ] || { echo "Usage: ./phoenixboot-dod secure media --iso <path> [--usb-device /dev/sdX]" >&2; exit 2; }
        if [ -n "$usb_device" ]; then
          ISO_PATH="$iso_path" USB_DEVICE="$usb_device" run_pf secureboot-create-usb
        else
          ISO_PATH="$iso_path" run_pf secureboot-create
        fi
        ;;
      mok-new)
        name=""
        cn=""
        while [ $# -gt 0 ]; do
          case "$1" in
            --name) name="${2:-}"; shift 2 ;;
            --cn) cn="${2:-}"; shift 2 ;;
            *)
              echo "Unknown secure mok-new option: $1" >&2
              exit 2
              ;;
          esac
        done
        NAME="${name:-PGMOK}" CN="${cn:-PhoenixGuard Module Key}" run_pf secure-mok-new
        ;;
      mok-enroll)
        cert_pem=""
        cert_der=""
        dry_run="0"
        while [ $# -gt 0 ]; do
          case "$1" in
            --cert-pem) cert_pem="${2:-}"; shift 2 ;;
            --cert-der) cert_der="${2:-}"; shift 2 ;;
            --dry-run) dry_run="1"; shift ;;
            *)
              echo "Unknown secure mok-enroll option: $1" >&2
              exit 2
              ;;
          esac
        done
        MOK_CERT_PEM="${cert_pem:-out/keys/mok/PGMOK.crt}" \
        MOK_CERT_DER="${cert_der:-out/keys/mok/PGMOK.der}" \
        MOK_DRY_RUN="$dry_run" \
        run_pf os-mok-enroll
        ;;
      mok-list)
        run_pf os-mok-list-keys
        ;;
      kmod-sign)
        module_path=""
        force="0"
        while [ $# -gt 0 ]; do
          case "$1" in
            --module) module_path="${2:-}"; shift 2 ;;
            --force) force="1"; shift ;;
            *)
              echo "Unknown secure kmod-sign option: $1" >&2
              exit 2
              ;;
          esac
        done
        [ -n "$module_path" ] || { echo "Usage: ./phoenixboot-dod secure kmod-sign --module <file|dir> [--force]" >&2; exit 2; }
        MODULE_PATH="$module_path" FORCE="$force" run_pf os-kmod-sign
        ;;
      *)
        echo "Unknown secure subcommand: ${sub:-<missing>}" >&2
        usage
        exit 2
        ;;
    esac
    ;;

  secure-keygen)
    run_pf secure-keygen
    ;;

  secure-make-auth)
    run_pf secure-make-auth
    ;;

  secure-enroll)
    run_pf secure-enroll-secureboot
    ;;

  secureboot-create)
    iso_path=""
    usb_device=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --iso) iso_path="${2:-}"; shift 2 ;;
        --usb-device) usb_device="${2:-}"; shift 2 ;;
        *)
          echo "Unknown secureboot-create option: $1" >&2
          exit 2
          ;;
      esac
    done
    [ -n "$iso_path" ] || { echo "Usage: ./phoenixboot-dod secureboot-create --iso <path> [--usb-device /dev/sdX]" >&2; exit 2; }
    if [ -n "$usb_device" ]; then
      ISO_PATH="$iso_path" USB_DEVICE="$usb_device" run_pf secureboot-create-usb
    else
      ISO_PATH="$iso_path" run_pf secureboot-create
    fi
    ;;

  # DoD-specific commands ---------------------------------------------------
  dod-check)
    cmd_dod_check
    ;;

  dod-audit-log)
    cmd_dod_audit_log
    ;;

  dod-status)
    cmd_dod_status
    ;;

  *)
    run_pf "$cmd" "$@"
    ;;
esac
